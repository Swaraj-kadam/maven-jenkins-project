pipeline {
  agent any

  tools {
    maven 'Maven'
  }

  stages {
    stage('clone'){
      steps {
        git 'https://github.com/Swaraj-kadam/maven-jenkins-project.git'
      }
    }

    stage('Build'){
      steps {
        bat 'mvn clean compile'
      }
    }

    stage('Test'){
      steps {
        bat 'mvn test'
      }
    }

    stage('Package'){
      steps {
        bat 'mvn package'
      }
    }
  }
}
